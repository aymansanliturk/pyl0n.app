{
  "name": "pyl0n",
  "version": "1.0.0",
  "description": "PYL0N Suite — Bid & Project Planning Tools",
  "author": "PYL0N",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icons": "python3 scripts/generate-icons.py",
    "download-libs": "node scripts/download-libs.js",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.pyl0n.suite",
    "productName": "PYL0N",
    "copyright": "Copyright © 2026 PYL0N",
    "files": [
      "*.html",
      "*.svg",
      "libs/**",
      "vendor/**",
      "main.js",
      "preload.js",
      "build/icon.*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "target": [
        { "target": "dmg",  "arch": ["x64", "arm64"] },
        { "target": "zip",  "arch": ["x64", "arm64"] }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.business",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "PYL0N ${version}",
      "icon": "build/icon.icns",
      "iconSize": 80,
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": { "width": 540, "height": 380 }
    }
  }
}
